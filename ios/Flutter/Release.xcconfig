#include? "Pods/Target Support Files/Pods-Runner/Pods-Runner.release.xcconfig"
#include "Generated.xcconfig"
// Allow arm64 for iOS Simulator on Apple Silicon (override Generated.xcconfig exclusion)
EXCLUDED_ARCHS[sdk=iphonesimulator*]=i386
// So linker finds Pods_Runner.framework (CocoaPods puts it in PODS_CONFIGURATION_BUILD_DIR root)
FRAMEWORK_SEARCH_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}"
